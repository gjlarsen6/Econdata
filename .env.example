# Copy this file to .env and fill in your API keys.
# ── FRED (mandatory) ──────────────────────────────────────────────────────────
# Free keys: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Sector APIs (optional — only needed when using --sector flag) ─────────────

# BEA (Bureau of Economic Analysis) — required for --sector bea
# Free key: https://apps.bea.gov/api/signup/
BEA_API_KEY=your_bea_api_key_here

# BLS (Bureau of Labor Statistics) — optional for --sector bls
# BLS works without a key at lower rate limits (25 req/day).
# Free key: https://www.bls.gov/developers/home.htm
BLS_API_KEY=your_bls_api_key_here

# Trading Economics — required for --sector tradingeconomics (commercial plan)
# https://tradingeconomics.com/api/
TE_CLIENT_KEY=your_te_client_key_here
TE_CLIENT_SECRET=your_te_client_secret_here
